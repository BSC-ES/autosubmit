{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "https://earth.bsc.es/autosubmit/config-schema",
    "title": "Autosubmit General Configuration Schema",
    "description": "Schema for the general configuration of the autosubmit workflow",
    "type": "object",
    "required": [
        "DEFAULT",
        "EXPERIMENT",
        "PROJECT",
        "CONFIG",
        "JOBS"
    ],
    "definitions": {
        "nonEmptyString": {
            "$type": "string",
            "minLength": 1,
            "description": "A string with at least one character."
        },
        "positiveInteger": {
            "$type": "integer",
            "minimum": 1,
            "description": "An integer greater than zero."
        },
        "nonNegativeInteger": {
            "$type": "integer",
            "minimum": 0,
            "description": "An integer greater than or equal to zero."
        },
        "boolean": {
            "oneOf": [
                {
                    "type": "boolean"
                },
                {
                    "type": "string",
                    "enum": [
                        "true",
                        "false",
                        "True",
                        "False"
                    ]
                }
            ],
            "$description": "A boolean or a string representation of a boolean"
        },
        "customConfigSpec": {
            "oneOf": [
                {
                    "type": "string",
                    "description": "Path to a single custom config file."
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "List of custom config files."
                },
                {
                    "type": "object",
                    "properties": {
                        "PRE": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "List of custom config files."
                        },
                        "POST": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "List of custom config files."
                        }
                    },
                    "additionalProperties": false,
                    "description": "PRE files load before experiment config, POST files after."
                }
            ]
        }
    },
    "defaultSection": {
        "type": "object",
        "description": "Experiment default parameters. EXPID nad HPCARCH are required.",
        "required": [
            "EXPID",
            "HPCARCH"
        ],
        "properties": {
            "EXPID": {
                "$ref": "#/definitions/nonEmptyString",
                "description": "4 characters experiment ID. (Example: a000)"
            },
            "HPCARCH": {
                "$ref": "#/definitions/nonEmptyString",
                "description": "Default HPC platform name. Must match a PLATFORMS key or be LOCAL."
            },
            "CUSTOM_CONFIG": {
                "$ref": "#/definitions/customConfigSpec"
            },
            "DESCRIPTION": {
                "type": "string",
                "description": "Experiment description."
            }
        }
    }
}
