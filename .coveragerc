# This is the Coverage.py configuration file. This is used by CI when running
# the tests and collecting coverage

[run]
branch = True
cover_pylib = False
concurrency = thread,multiprocessing
data_file = .coverage
disable_warnings =
    trace-changed
    module-not-python
    module-not-imported
    no-data-collected
    module-not-measured
omit =
    tests/*
    autosubmit/job/template/common.py
source = autosubmit
timid = False
sigterm = True

[report]
# Preferred over exclude_lines, already excludes pragma no cover and ... (ellipsis);
# ref: https://coverage.readthedocs.io/en/7.12.0/config.html#report-exclude-also
exclude_also =
    # Don't complain if tests don't hit defensive assertion code:
    raise NotImplementedError
    raise NotImplemented
    return NotImplemented

    # Ignore type checking code:
    if (typing\.)?TYPE_CHECKING:
    @overload( |$)

    # Ignore abstract methods
    @(abc\.)?abstractmethod

    # Ignore pass statements
    ^\s*pass\s*$

    # Main function
    if __name__ == .__main__.:

    # Protocol classes
    class .*\bProtocol\):

    # Ignore logging statements
    ^\s*Log\.

fail_under=0
ignore_errors = False
omit =
    tests/*
    autosubmit/job/template/common.py
precision = 2
show_missing = False
skip_covered = False
sort = Name

[html]
directory = htmlcov

[xml]
output = coverage.xml
package_depth = 99
